# Copy this file to .env.local and fill in your real values.
# Never commit .env.local to git.

# Supabase project credentials (safe to expose in browser -- anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://kdpcpdgskjkfcvoieiuw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key -- server-side only, never expose to browser
# Used only in server actions/edge functions that need to bypass RLS.
# For most dashboard queries, use the anon key + user session (RLS applies).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
